<?xml version="1.0"?>
<robot name="robotarm">
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.06"/>
      </geometry>
      <origin xyz="0 0 0.025"/>
    </collision>
  </link>

  <link name="column_link">
    <visual>
      <geometry>
        <cylinder length="0.12" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0.06"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.12" radius="0.035"/>
      </geometry>
      <origin xyz="0 0 0.06"/>
    </collision>
  </link>

  <joint name="base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="column_link"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.0" upper="3.0" velocity="0.5"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <geometry>
        <cylinder length="0.14" radius="0.02"/>
      </geometry>
      <origin xyz="0 0 0.07"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.14" radius="0.03"/>
      </geometry>
      <origin xyz="0 0 0.07"/>
    </collision>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="column_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.12"/>
    <axis xyz="0 1 0"/>
    <limit effort="81" lower="-0.52359878" upper="1.39626340" velocity="0.5"/>
  </joint>

  <link name="lower_arm_link">
    <visual>
      <geometry>
        <cylinder length="0.15" radius="0.015"/>
      </geometry>
      <origin xyz="0 0 0.075"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.15" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 0.075"/>
    </collision>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="lower_arm_link"/>
    <origin xyz="-0.025 0 0.14"/>
    <axis xyz="0 1 0"/>
    <limit effort="81" lower="-0.69813170" upper="2.44346095" velocity="0.5"/>
  </joint>

  <!-- Tool tip frame at the physical end of the lower arm.
       lower_arm_link visual length is 0.15 m along local +Z,
       so the tip is at z = 0.15 in lower_arm_link frame. -->
  <link name="tool_tip_link">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <origin xyz="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
  </link>

  <joint name="tool_tip_fixed_joint" type="fixed">
    <parent link="lower_arm_link"/>
    <child link="tool_tip_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <ros2_control name="RobotArmSystem" type="system">
    <hardware>
      <plugin>robotarm_hardware/RobotArmSystem</plugin>
    </hardware>

    <joint name="base_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="shoulder_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="elbow_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
